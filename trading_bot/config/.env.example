# ============================================================================
# TRADING BOT - ENVIRONMENT VARIABLES EXAMPLE
# ============================================================================
# Copier ce fichier en .env et remplir avec vos paramètres réels
# NEVER commit .env file with real secrets to version control

# ============================================================================
# API KEYS ET CREDENTIALS (SECRETS)
# ============================================================================
# API Keys - NEVER commit real keys
API_KEY_EXCHANGE_PRIMARY=your_api_key_here
API_SECRET_EXCHANGE_PRIMARY=your_api_secret_here
API_PASSPHRASE_EXCHANGE_PRIMARY=your_passphrase_here

# Backup exchange
API_KEY_EXCHANGE_BACKUP=your_backup_api_key_here
API_SECRET_EXCHANGE_BACKUP=your_backup_api_secret_here

# Bloomberg API (si utilisé)
BLOOMBERG_API_KEY=your_bloomberg_key_here

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL_ALERTS=#trading-alerts
SLACK_CHANNEL_REPORTS=#trading-reports

# Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
EMAIL_RECIPIENTS=risk@yourfirm.com,trading@yourfirm.com

# ============================================================================
# ENVIRONNEMENT
# ============================================================================
ENVIRONMENT=production
# Options: development, staging, production, backtest

APP_NAME=TradingBotRiskManager
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot
REDIS_URL=redis://localhost:6379/0
SQLITE_DB_PATH=./data/trading_bot.db

# ============================================================================
# TRADING PARAMETERS
# ============================================================================
INITIAL_CAPITAL_USD=1000000
BASE_CURRENCY=USD
TRADING_ACCOUNT_ID=your_account_id

# ============================================================================
# RISK PARAMETERS
# ============================================================================
MAX_RISK_PER_TRADE_PCT=2.0
MAX_CONCURRENT_POSITIONS=6
DAILY_DRAWDOWN_LIMIT_PCT=5.0
MONTHLY_DRAWDOWN_LIMIT_PCT=15.0

# ============================================================================
# MARKET DATA
# ============================================================================
MARKET_DATA_PROVIDER=ccxt
# Options: ccxt, bloomberg, refinitiv, custom
MARKET_DATA_REFRESH_INTERVAL_SECONDS=5
HISTORICAL_DATA_LOOKBACK_DAYS=252

# ============================================================================
# EXECUTION
# ============================================================================
EXECUTION_MODE=live
# Options: live, paper, backtest
ORDER_EXECUTION_TIMEOUT_MS=100
MAX_ORDER_RETRIES=3

# ============================================================================
# MONITORING ET ALERTING
# ============================================================================
ENABLE_SLACK_ALERTS=true
ENABLE_EMAIL_ALERTS=true
ENABLE_PAGERDUTY=false
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key_here

ALERT_ON_TRADE_BLOCK=true
ALERT_ON_CIRCUIT_BREAKER=true
ALERT_ON_RISK_THRESHOLD_BREACH=true
ALERT_ON_SYSTEM_ERROR=true

# ============================================================================
# MONITORING SANTE SYSTEME
# ============================================================================
HEALTH_CHECK_INTERVAL_SECONDS=30
CPU_USAGE_THRESHOLD_PCT=80
MEMORY_USAGE_THRESHOLD_PCT=85
DISK_SPACE_THRESHOLD_GB=10

# ============================================================================
# BACKUP ET RECOVERY
# ============================================================================
ENABLE_AUTOMATIC_BACKUPS=true
BACKUP_FREQUENCY_HOURS=6
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/data/backups

# ============================================================================
# TIMEZONE ET DATES
# ============================================================================
TIMEZONE=UTC
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00

# ============================================================================
# DEBUG ET DEVELOPPEMENT
# ============================================================================
DEBUG_MODE=false
ENABLE_PROFILING=false
ENABLE_MEMORY_TRACKING=false
LOG_API_CALLS=false
LOG_DETAILED_TRADES=false